{
  "name": "food-delivery-backend",
  "version": "1.0.0",
  "description": "Swiggy-like food delivery system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "coverage": "jest --coverage --runInBand --detectOpenHandles --forceExit --coverageReporters=\"json-summary\" \"text\"",
    "security:audit": "node scripts/security-audit.js",
