    "qa": "node scripts/qa-gate.js",
    "system:report": "node scripts/generate-system-report.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.31.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
