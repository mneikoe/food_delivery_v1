			"item": [
				{
					"name": "Create Razorpay Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.razorpayOrderId) {",
									"    pm.environment.set(\"lastRazorpayOrderId\", res.razorpayOrderId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
