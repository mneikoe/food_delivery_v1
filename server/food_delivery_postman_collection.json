								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"raj117557@gmail.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/send-email-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"send-email-otp"
							]
						},
						"description": "Sends a 6-digit verification OTP via Nodemailer. Rate-limited to max 5 requests per IP per 10 minutes, max 3 requests per email address per 10 minutes, and 60-second cooldown."
					},
					"response": []
				},
				{
					"name": "Verify Email OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const responseJson = pm.response.json();",
									"if (responseJson.token) {",
									"    pm.environment.set(\"token\", responseJson.token);",
									"    pm.globals.set(\"token\", responseJson.token);",
									"    console.log(\"Saved auth token to environment.\");",
									"}",
									"pm.test(\"Verify OTP - Success\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400, 429]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"raj117557@gmail.com\",\n    \"otp\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-email-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"verify-email-otp"
							]
						},
						"description": "Verifies 6-digit OTP and returns user payload with JWT auth token. OTP will be invalidated after 5 failed attempts."
					},
					"response": []
				},
